# Copy to `deploy.env` at the repo root and fill in. Every value also accepts
# a real environment-variable override, so CI can run `./scripts/deploy.sh`
# without a file on disk.

# SSH target the script will connect to. Format: user@host
DEPLOY_SSH_TARGET=ubuntu@your-server.example.com

# Where the cogent42-team repo lives on the server.
DEPLOY_APP_DIR=/home/ubuntu/cogent42-team

# Admin bearer token — the value of ADMIN_TOKEN in the server's `.env`.
# Used to call the per-user bot restart endpoint after a bot image rebuild.
DEPLOY_ADMIN_TOKEN=

# Control-plane URL as reachable from inside the SSH session (usually localhost).
DEPLOY_CONTROL_PLANE_URL=http://127.0.0.1:8080

# Postgres credentials — must match POSTGRES_USER / POSTGRES_DB on the server.
DEPLOY_PG_USER=cogent
DEPLOY_PG_DB=cogent42_team
