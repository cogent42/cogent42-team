# --- Postgres ---
POSTGRES_USER=cogent
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=cogent42_team
# DATABASE_URL is what host-run scripts use (migrate). Postgres is published on 127.0.0.1:5432.
# Inside docker-compose, services build their own DATABASE_URL using the `postgres` service name.
DATABASE_URL=postgres://cogent:change-me-strong-password@127.0.0.1:5432/cogent42_team

# --- Platform secrets ---
# 32-byte base64 key for column encryption (libsodium secretbox)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=

# Admin bearer token for control-plane API + UI
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=

# Public contact email for the landing page ("talk to your administrator at …").
# Optional — leave blank for generic copy.
ADMIN_CONTACT_EMAIL=

# --- LLM (Claude Code SDK auth) ---
# We do NOT use ANTHROPIC_API_KEY. Every LLM call goes through @anthropic-ai/claude-agent-sdk,
# which spawns the `claude` CLI inside each container and authenticates using your existing
# Claude Code session (mounted from CLAUDE_CODE_HOME below). Install Claude Code on this host
# and run `claude` once interactively to authenticate before bringing the stack up.
CLAUDE_CODE_HOME=

# Used for embeddings (text-embedding-3-small @ 1024d)
OPENAI_API_KEY=

# --- Gmail OAuth (Google Cloud project) ---
# Create at https://console.cloud.google.com/apis/credentials → OAuth client ID (web)
# Add redirect URI: http://<your-host>:8080/api/gmail/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/gmail/oauth/callback
CONTROL_PLANE_PUBLIC_URL=http://localhost:8080

# --- Control plane ---
CONTROL_PLANE_PORT=8080
CONTROL_PLANE_PUBLIC_URL=http://localhost:8080

# Bot container provisioning
BOT_IMAGE=cogent42-team/bot:latest
BOT_NETWORK=cogent42-internal
BOT_MEM_LIMIT=512m
BOT_CPU_LIMIT=0.5

# Extractor / gmail worker tuning
EXTRACTION_CONCURRENCY=4
GMAIL_POLL_INTERVAL_SEC=60
KNOWLEDGE_FRESHNESS_DAYS=90
